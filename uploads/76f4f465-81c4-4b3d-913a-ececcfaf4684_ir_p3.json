    },
    {
      "id": "p_3",
      "text": "I. Introduction",
      "style": "Heading 1",
      "is_bold": false,
      "font_size": null,
      "type": "heading",
      "heading_level": 1
    },
    {
      "id": "p_4",
      "text": "Deep learning has transformed AI (Goodfellow et al., 2016).",
      "style": "Normal",
      "is_bold": false,
      "font_size": null,
      "type": "body",
      "heading_level": 0
    },
    {
      "id": "p_5",
      "text": "II. Literature Review",
      "style": "Heading 1",
      "is_bold": false,
      "font_size": null,
      "type": "heading",
      "heading_level": 1
    },
    {
      "id": "p_6",
      "text": "Many systems use neural networks (Smith & Jones, 2020).",
      "style": "Normal",
      "is_bold": false,
      "font_size": null,
      "type": "body",
      "heading_level": 0
    },
    {
      "id": "p_7",
      "text": "III. Methodology",
      "style": "Heading 1",
      "is_bold": false,
      "font_size": null,
      "type": "heading",
      "heading_level": 1
    },
    {
      "id": "p_8",
      "text": "We use a multilayer perceptron approach.",
      "style": "Normal",
      "is_bold": false,
      "font_size": null,
      "type": "body",
      "heading_level": 0
    },
    {
      "id": "p_9",
      "text": "IV. Results",
      "style": "Heading 1",
      "is_bold": false,
      "font_size": null,
      "type": "heading",
      "heading_level": 1
    },
    {
      "id": "p_10",
      "text": "Validation scores reached 95%.",
      "style": "Normal",
      "is_bold": false,
      "font_size": null,
      "type": "body",
      "heading_level": 0
    },
    {
      "id": "p_11",
      "text": "V. Conclusion",
      "style": "Heading 1",
      "is_bold": false,
      "font_size": null,
      "type": "heading",
      "heading_level": 1
